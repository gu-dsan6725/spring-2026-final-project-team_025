# Copy this file to demo/.env (or repo root .env) and fill in your keys.
# The server reads from .env automatically via python-dotenv.

# Required: Groq API key for LLM-based extraction.
# Get one free at https://console.groq.com
# Without this key the system falls back to rule-based extraction (no LLM).
GROQ_API_KEY=

# Optional: OpenAI key — only needed if you run the evaluation judge scripts.
# OPENAI_API_KEY=your_openai_api_key_here
